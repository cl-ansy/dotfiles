# Open a tmux dev session with a configurable pane layout for a directory.
# Usage: muxd [directory]

# --- Layout config ---
# Each pane: "split_flag|command" (first pane has no split)
# Split flags:
# -h horizontal, -v vertical
# -f new pane spans full width or height
# -d dont focus new pane
# -b put pane on other side (left or top)
local panes=(
  "|"            # pane 1: shell (no command)
  "|claude".     # pane 2: claude below pane 1 shell
  "-fh|lazygit"  # pane 3: lazygit, full size horizontal split
)
local focus=1    # which pane to focus after setup
# -----------------

local dir="${1:-$PWD}"
dir="${dir:A}"

if [[ ! -d "$dir" ]]; then
  echo "muxd: not a directory: $dir" >&2
  return 1
fi

local name="muxd-${dir:t}"
name="${name//./-}"

if tmux has-session -t "=$name" 2>/dev/null; then
  if [[ -z "$TMUX" ]]; then
    tmux attach-session -t "$name"
  else
    tmux switch-client -t "$name"
  fi
  return
fi

if [[ -z "$TMUX" ]]; then
  tmux new-session -d -s "$name" -c "$dir"
else
  tmux new-window -n "$name" -c "$dir"
fi

local split cmd
for pane in "${panes[@]:1}"; do
  split="${pane%%|*}"
  cmd="${pane#*|}"
  if [[ -z "$TMUX" ]]; then
    tmux split-window $split -t "$name" -c "$dir" $cmd
  else
    tmux split-window $split -c "$dir" $cmd
  fi
done

tmux select-pane -t "$focus"

if [[ -z "$TMUX" ]]; then
  tmux attach-session -t "$name"
fi
